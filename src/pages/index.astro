---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Tension from '../components/Tension.astro';
import ForWhom from '../components/ForWhom.astro';
import Method from '../components/Method.astro';
import Team from '../components/Team.astro';
import Results from '../components/Results.astro';
import Placements from '../components/Placements.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

import content from '../content/pages/home.json';
---

<Layout title="Krestam — College & Career Counseling for India & Gulf Students">
  <Hero {...content.hero} />
  <Tension />
  <ForWhom {...content.forWhom} />
  <Method {...content.method} />
  <Team />
  <Results {...content.results} />
  <Placements />
  <Services {...content.services} />
  <Testimonials {...content.testimonials} />
  <FAQ {...content.faq} />
  <FinalCTA {...content.finalCta} />
  <Footer {...content.footer} />
  <WhatsAppButton {...content.whatsapp} />
</Layout>
