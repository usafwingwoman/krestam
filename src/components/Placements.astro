---
const schools = [
  { name: "Harvard University", tier: "Ivy League" },
  { name: "Stanford University", tier: "Top 5" },
  { name: "MIT", tier: "Top 5" },
  { name: "California Institute of Technology", tier: "Top 10" },
  { name: "Columbia University", tier: "Ivy League" },
  { name: "Cornell University", tier: "Ivy League" },
  { name: "Dartmouth College", tier: "Ivy League" },
  { name: "Carnegie Mellon University", tier: "Top 25" },
  { name: "Duke University", tier: "Top 10" },
  { name: "New York University", tier: "Top 25" },
  { name: "University of Texas at Austin", tier: "Top 50" },
  { name: "University of California Berkeley", tier: "Top 15" },
]
---

<section class="py-24 bg-white border-t border-neutral-100">
  <div class="max-w-content mx-auto px-10">

    <div class="mb-16">
      <p class="text-xs font-medium tracking-[2px] uppercase text-neutral-400 mb-4">
        Where our students go
      </p>
      <h2 class="font-display font-extrabold text-3xl tracking-tight mb-4">
        Some of the most selective universities in the world.
      </h2>
      <p class="text-sm text-neutral-500">
        Our students have earned acceptance to institutions that reject the vast majority of applicants.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-neutral-100">
      {schools.map((school) => (
        <div class="bg-white p-8 flex flex-col gap-2 hover:bg-neutral-50 transition-colors">
          <span class="text-xs font-medium tracking-[1px] uppercase text-brand-amber-dark">
            {school.tier}
          </span>
          <span class="font-display font-bold text-lg leading-tight text-brand-dark">
            {school.name}
          </span>
        </div>
      ))}
    </div>

    <p class="text-xs text-neutral-400 mt-6">
      Partial list. Additional placements available upon request.
    </p>

  </div>
</section>
