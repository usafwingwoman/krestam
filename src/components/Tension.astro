---
// Content is hardcoded — not driven by props or home.json
const tensions = [
  {
    number: "01",
    text: "The applicant pool is global now. Your child isn't competing with the kid next door. They're competing with students from 150 countries who've been coached for this."
  },
  {
    number: "02",
    text: "A good rank gets you considered. A compelling narrative gets you accepted. Most students only work on one of these."
  },
  {
    number: "03",
    text: "Getting into a great university is not the same as building a great career. Most counseling stops at acceptance. Ours doesn't."
  }
]
---

<section class="py-24 border-t border-neutral-100">
  <div class="max-w-content mx-auto px-10">

    <p class="text-xs font-medium tracking-[2px] uppercase text-neutral-400 mb-16">
      The problem
    </p>

    <div class="flex flex-col divide-y divide-neutral-100">
      {tensions.map((item) => (
        <div class="flex items-start gap-12 py-12">

          <span class="font-display font-extrabold text-5xl leading-none text-neutral-200 shrink-0 w-16">
            {item.number}
          </span>

          <p class="font-display font-bold text-2xl md:text-3xl leading-snug tracking-tight text-brand-dark max-w-3xl">
            {item.text}
          </p>

        </div>
      ))}
    </div>

  </div>
</section>
