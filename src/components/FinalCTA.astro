---
interface Props {
  eyebrow: string;
  headline: string;
  body: string;
  cta: string;
  ctaHref: string;
}

const { eyebrow, headline, body, cta, ctaHref } = Astro.props;
---

<section class="bg-brand-orange py-20 px-6">
  <div class="max-w-content mx-auto">
    <div class="max-w-xl">
      <p class="font-body text-xs font-medium tracking-widest uppercase text-white/70 mb-4">{eyebrow}</p>
      <h2 class="font-display font-extrabold text-[28px] leading-[1.05] tracking-[-0.5px] text-white mb-4 md:text-[36px]">
        {headline}
      </h2>
      <p class="font-body text-white/80 text-base leading-relaxed mb-8">{body}</p>
      <a
        href={ctaHref}
        class="inline-block bg-white text-brand-orange font-body font-semibold text-sm px-7 py-4 rounded-md hover:opacity-90 transition-opacity"
      >
        {cta}
      </a>
    </div>
  </div>
</section>
