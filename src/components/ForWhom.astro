---
interface Card {
  title: string;
  description: string;
  tag: string;
}

interface Props {
  headline: string;
  cards: Card[];
}

const { headline, cards } = Astro.props;
---

<section class="bg-neutral-50 py-20 px-6">
  <div class="max-w-content mx-auto">

    <h2 class="font-display font-extrabold text-[28px] leading-[1.1] tracking-[-0.5px] text-brand-black mb-10 md:text-[32px]">
      {headline}
    </h2>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {cards.map((card) => (
        <div class="bg-white border border-[0.5px] border-neutral-100 rounded-lg p-7 flex flex-col gap-4">
          <h3 class="font-display font-bold text-[17px] text-brand-black">{card.title}</h3>
          <p class="font-body text-sm text-neutral-600 leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
