---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  headlineAccent: string;
  subheadline: string;
  cta: string;
  ctaHref: string;
  stats: Stat[];
}

const { eyebrow, headline, headlineAccent, subheadline, cta, ctaHref, stats } = Astro.props;
---

<section class="bg-neutral-50 pt-20 pb-20 px-6 md:pt-28">
  <div class="max-w-content mx-auto">

    <div class="max-w-2xl">
      <p class="font-body text-xs font-medium tracking-widest uppercase text-brand-amber-dark mb-5">
        {eyebrow}
      </p>
      <h1 class="font-display text-[42px] leading-[1.05] tracking-[-1.5px] text-brand-black mb-5 md:text-[56px] text-balance">
        <span class="font-extrabold">{headline}</span> <em class="text-brand-amber-dark font-extrabold">{headlineAccent}</em>
      </h1>
      <p class="font-body text-content-on-light-muted text-[17px] leading-relaxed mb-8 max-w-lg">
        {subheadline}
      </p>
      <a
        href={ctaHref}
        class="inline-block bg-brand-amber text-white font-body font-medium text-sm px-6 py-3.5 rounded-md hover:opacity-90 transition-opacity"
      >
        {cta}
      </a>
    </div>

    <div class="mt-16 grid grid-cols-3 gap-[2px] max-w-md">
      {stats.map((stat) => (
        <div class="bg-neutral-50 border border-neutral-300 p-5 flex flex-col gap-1 hover:bg-white transition-colors">
          <p class="font-display font-extrabold text-2xl text-brand-black tracking-tight">{stat.value}</p>
          <p class="font-body text-xs text-content-on-light-muted leading-snug">{stat.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
