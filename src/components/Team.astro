---
const sage = {
  initials: "SJP",
  photo: "/images/military-profile-photo-full.png",
  photoLeft: false,
  eyebrow: "Co-founder & Chief Strategist",
  name: "Sage J Phoenix",
  title: "U.S. Air Force Officer · Strategic Planner · Operator",
  tagline: "A Standard Forged in Combat: Excellence in All We Do.",
  bio: [
    "Sage J. Phoenix — known universally as Chief — is the kind of operator most organizations never encounter, and immediately recognize when they do.",
    "As a rated Navigator and Mission Crew Commander — where the title Chief was first earned — Chief flew 30+ combat missions and 250+ combat hours aboard one of the most classified aircraft in the U.S. military. Chief graduated #1 of 57 from Joint Specialized Undergraduate Navigator Training — taking home both academic awards. Air Medal for meritorious service.",
    "That standard didn't retire with the uniform.",
    "Across two decades of post-military work, Chief has built a reputation for one thing: taking complex challenges and engineering them into clear, executable outcomes. Three master's degrees — MBA, Financial Management, and Real Estate. Twenty-plus years developing high performers, designing systems that produce results, and delivering with the same zero-defect discipline the Air Force demanded.",
    "At Krestam, Chief brings the same standards applied to combat operations to the mission of positioning your student for the future they deserve: Meticulous planning. Precise execution. Zero defects. Every time.",
    "Your child's application is a mission. Chief treats it like one."
  ],
  stats: [
    { label: "Class rank", value: "#1 of 57" },
    { label: "Academic awards", value: "Both" },
    { label: "Combat missions", value: "30+" },
    { label: "Combat hours", value: "250+" },
    { label: "Clearance held", value: "TS/SCI" },
    { label: "Meritorious service", value: "Air Medal" },
    { label: "Master's degrees", value: "3" },
    { label: "Revenue growth led", value: "560%" },
  ]
}

const usman = {
  initials: "U",
  photo: null,
  photoLeft: true,
  eyebrow: "Co-founder & Lead Counselor",
  name: "Prof. Usman",
  title: "MIT-Trained · Adjunct Professor · Global Advisor",
  tagline: "MIT-Trained.\nGlobally Experienced.\nInvested in Every Student.",
  bio: [
    "Some advisors know about universities. Prof. Usman knows how they think — because he's spent decades working inside them, alongside them, and at the highest levels of the institutions that shape them.",
    "Three master's degrees — two from MIT, one from a joint MIT-Harvard program. Decades of global advisory experience across industries and institutions on multiple continents. Currently teaching at the University of Texas-Dallas, where he sits inside the American academic system your student is trying to enter.",
    "He has spent his career integrating complex systems into coherent strategies. At Krestam, that means one thing: seeing your student as a complete picture — who they are, what they're capable of, and where they're going — and building a case that elite admissions committees can't ignore."
  ],
  stats: [
    { label: "Master's degrees", value: "3" },
    { label: "MIT degrees", value: "2" },
    { label: "MIT-Harvard joint", value: "1" },
    { label: "Current role", value: "Adjunct Prof." },
    { label: "University", value: "UT Dallas" },
  ]
}

const founders = [sage, usman]
---

<section class="py-24 border-t border-neutral-100">
  <div class="max-w-content mx-auto px-10">

    <p class="text-xs font-medium tracking-[2px] uppercase text-neutral-400 mb-16">
      Our team
    </p>

    <div class="flex flex-col gap-20">
      {founders.map((founder) => (
        <div class={`grid grid-cols-1 gap-12 items-stretch pt-16 border-t border-neutral-100 first:border-t-0 first:pt-0 ${founder.photoLeft ? 'md:grid-cols-[40%_60%]' : 'md:grid-cols-[60%_40%]'}`}>

          <div class={`flex flex-col gap-5 ${founder.photoLeft ? 'md:order-2' : 'md:order-1'}`}>
            <div>
              <p class="text-xs font-medium tracking-[2px] uppercase text-brand-amber-dark mb-3">
                {founder.eyebrow}
              </p>
              <h2 class="font-display font-extrabold text-3xl tracking-tight mb-1">
                {founder.name}
              </h2>
              <p class="text-sm text-content-on-light-muted">{founder.title}</p>
            </div>

            <p class="font-display font-bold text-xl leading-snug pl-4 border-l-[3px] border-brand-amber whitespace-pre-line">
              {founder.tagline}
            </p>

            <div class="flex flex-col gap-3">
              {founder.bio.map((para) => (
                <p class="text-sm leading-relaxed text-content-on-light-muted">{para}</p>
              ))}
            </div>

            <div class="grid grid-cols-2 gap-2 mt-2">
              {founder.stats.map((stat) => (
                <div class="bg-neutral-50 rounded-lg p-3">
                  <p class="text-xs text-neutral-400 mb-1">{stat.label}</p>
                  <p class="font-display font-bold text-sm text-brand-dark">{stat.value}</p>
                </div>
              ))}
            </div>
          </div>

          <div class={`flex flex-col gap-6 ${founder.photoLeft ? 'md:order-1' : 'md:order-2'}`}>
            {founder.photo ? (
              <div class="h-full min-h-[600px] rounded-xl overflow-hidden">
                <img
                  src={founder.photo}
                  alt={`Photo of ${founder.name}`}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="sticky top-8 min-h-[600px] bg-neutral-50 border border-thin border-neutral-100 rounded-xl flex items-center justify-center">
                <div class="text-center">
                  <span class="font-display font-extrabold text-6xl text-neutral-400">
                    {founder.initials}
                  </span>
                  <p class="text-xs text-neutral-400 mt-2">Photo placeholder</p>
                </div>
              </div>
            )}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
